<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Dark Glass Background -->
    <gradient
        android:angle="315"
        android:startColor="#1E293B"
        android:centerColor="#111827"
        android:endColor="#050505" />

    <!-- Rounded Corners -->
    <corners android:radius="18dp" />

    <!-- Neon Border -->
    <stroke
        android:width="1.5dp"
        android:color="#4FC3F7" />

    <!-- Padding -->
    <padding
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="12dp" />

</shape>